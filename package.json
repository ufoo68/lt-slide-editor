{
  "name": "lt-slide-editor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"Remove-Item Env:NODE_TLS_REJECT_UNAUTHORIZED -ErrorAction SilentlyContinue; $env:NEXT_TELEMETRY_DISABLED='1'; node ./node_modules/next/dist/bin/next dev -p 3000\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "db:up": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/local-db.ps1 up",
    "db:down": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/local-db.ps1 down",
    "db:restart": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/local-db.ps1 restart",
    "db:logs": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/local-db.ps1 logs",
    "db:status": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/local-db.ps1 status",
    "db:reset": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/local-db.ps1 reset",
    "db:migrate": "npm run prisma:generate && npm run prisma:migrate",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "@prisma/client": "^5.22.0",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.7.0",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0",
    "next": "^16.2.4",
    "prisma": "^5.22.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanitize-html": "^2.13.1",
    "slugify": "^1.6.6",
    "tailwind-merge": "^2.5.4",
    "typescript": "^6.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14"
  }
}
