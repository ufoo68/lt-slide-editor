{
  "name": "lt-slide-editor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"Remove-Item Env:NODE_TLS_REJECT_UNAUTHORIZED -ErrorAction SilentlyContinue; $env:NEXT_TELEMETRY_DISABLED='1'; node ./node_modules/next/dist/bin/next dev -p 3000\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose stop postgres",
    "db:restart": "docker compose restart postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:status": "docker compose ps postgres",
    "db:reset": "docker compose down -v && docker compose up -d --wait postgres",
    "db:migrate": "npm run prisma:generate && npm run prisma:migrate",
    "db:studio": "prisma studio",
    "local:up": "docker compose up -d --wait postgres firebase-auth minio minio-init",
    "local:down": "docker compose down",
    "local:logs": "docker compose logs -f postgres firebase-auth minio",
    "local:reset": "docker compose down -v && docker compose up -d --wait postgres firebase-auth minio minio-init",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node --env-file-if-exists=.env --env-file-if-exists=.env.local ./node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node --env-file-if-exists=.env --env-file-if-exists=.env.local ./node_modules/prisma/build/index.js migrate deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.946.0",
    "@google-cloud/storage": "^7.14.0",
    "@google/genai": "^1.52.0",
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.2.4",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.7.0",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.14.0",
    "next": "^16.2.4",
    "prisma": "^5.22.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanitize-html": "^2.13.1",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.5.0",
    "typescript": "^6.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.13.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.2.4"
  }
}
