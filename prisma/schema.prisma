generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeckVisibility {
  private
  public
}

enum DeckExportType {
  pdf
  html
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String  @unique
  email       String
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  decks        Deck[]
  slideLibrary SlideLibraryItem[]
  imageLibrary ImageLibraryItem[]
}

model Deck {
  id         String         @id @default(cuid())
  userId     String
  title      String
  slug       String         @unique
  markdown   String
  visibility DeckVisibility @default(private)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions DeckVersion[]
  assets   DeckAsset[]
  exports  DeckExport[]

  @@index([userId])
  @@index([visibility])
}

model DeckVersion {
  id        String   @id @default(cuid())
  deckId    String
  markdown  String
  createdAt DateTime @default(now())

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
}

model DeckAsset {
  id          String   @id @default(cuid())
  deckId      String
  storagePath String
  contentType String
  createdAt   DateTime @default(now())

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
}

model DeckExport {
  id          String         @id @default(cuid())
  deckId      String
  type        DeckExportType
  storagePath String
  createdAt   DateTime       @default(now())

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
}

model SlideLibraryItem {
  id        String   @id @default(cuid())
  userId    String
  title     String
  markdown  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model ImageLibraryItem {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  storagePath String
  contentType String
  size        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}
